  "info": {
    "title": "Liquidity Bot API",
    "description": "API для управления ликвидностью на Raydium CLMM",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "swap",
      "description": "Операции обмена токенов"
    },
    {
      "name": "liquidity",
      "description": "Управление ликвидностью"
    },
    {
      "name": "monitoring",
      "description": "Мониторинг позиций"
    },
    {
      "name": "transaction",
      "description": "История транзакций"
    },
    {
      "name": "auth",
      "description": "Аутентификация"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "JWT-auth": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "name": "JWT",
        "description": "Enter JWT token",
        "in": "header"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "Имя пользователя",
            "example": "admin",
            "minLength": 3
          },
          "password": {
            "type": "string",
            "description": "Пароль",
            "example": "password123",
            "minLength": 6
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "TokenResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "john_doe",
            "minLength": 3
          },
          "password": {
            "type": "string",
            "example": "SecurePass123",
            "minLength": 6
          },
          "role": {
            "type": "string",
            "example": "vault",
            "enum": [
              "vault",
              "pro"
            ]
          }
        },
        "required": [
          "username",
          "password",
          "role"
        ]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "SetupPositionDto": {
        "type": "object",
        "properties": {
          "poolId": {
            "type": "string",
            "description": "ID пула",
            "example": "3ucNos4NbumPLZNWztqGHNFFgkHeRMBQAVemeeomsUxv"
          },
          "baseMint": {
            "type": "string",
            "description": "Адрес базового токена (mint)",
            "example": "So11111111111111111111111111111111111111112"
          },
          "quoteMint": {
            "type": "string",
            "description": "Адрес котируемого токена (mint)",
            "example": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
          },
          "inputAmount": {
            "type": "number",
            "description": "Количество входного токена",
            "example": 1.5,
            "minimum": 0
          },
          "priceRangePercent": {
            "type": "number",
            "description": "Процент ценового диапазона",
            "example": 2,
            "minimum": 0.1,
            "maximum": 100
          }
        },
        "required": [
          "baseMint",
          "quoteMint",
          "inputAmount",
          "priceRangePercent"
        ]
      },
      "ClosePositionDto": {
        "type": "object",
        "properties": {
          "nftMint": {
            "type": "string",
            "description": "NFT Mint адрес позиции",
            "example": "5HauEoJa6tcKBy1vofNAxnEDiMpC7H6V9L5TgLwFYNfd"
          }
        },
        "required": [
          "nftMint"
        ]
      },
      "IncreasePositionDto": {
        "type": "object",
        "properties": {
          "nftMint": {
            "type": "string",
            "description": "NFT Mint адрес позиции",
            "example": "5HauEoJa6tcKBy1vofNAxnEDiMpC7H6V9L5TgLwFYNfd"
          },
          "inputAmount": {
            "type": "number",
            "description": "Input Amount",
            "example": "1"
          }
        },
        "required": [
          "nftMint",
          "inputAmount"
        ]
      },
      "CreateConfigDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
}